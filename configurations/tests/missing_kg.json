{
  "fine_tuning": {
    "skip_base_eval": false,
    "skip_baseline": false,
    "save_predictions": true,
    "generate_plots": true,
    "generate_table": true,

    "resuts_json_file": "results.json",
    "summary_csv_file": "summary.csv",
    "summary_plot_file": "experiment_plot.png",
    "summary_table_file": "experiment_table.png",

    "generate_datasets": false,
    "train_with_rules_samples": 10,
    "train_without_rules_samples": 5,
    "test_samples": 3,

    "model_name": "meta-llama/Llama-3.2-1B-Instruct",
    "model_alias": "LLaMA-3.2-1B",
    "context_window": 512,

    "per_device_batch_size": 1,
    "num_train_epochs": 1.0,
    "max_steps": 500, 
    "learning_rate": 2e-3,
    "warmup_steps": 10,
    "optim": "paged_adamw_8bit",
    "gradient_accumulation_steps": 4,
    "logging_steps": 50,
    "save_steps": 100,

    "lora_r": 16,
    "lora_alpha": 64,
    "lora_dropout": 0.1,
    "lora_bias": "none",
    "lora_task_type": "CAUSAL_LM"
  },
  "cot_generation": {
    "max_rules": 100,
    "max_samples_per_rule": 100,
    "rule_summary_file": "rules_summary.txt"
  },
  "data": {
    "input_dir": ".data/",
    "output_dir": ".experiments/"
  },
  "hardware": {
    "n_gpus": 1,
    "device": "gpu",
    "precision": "float16",
    "max_memory_mb": 40960
  }
}